import { jest } from '@jest/globals';
import React from 'react';

// Mock react-dropzone
jest.mock('react-dropzone', () => ({
  useDropzone: ({ onDrop, accept, disabled }: any) => ({
    getRootProps: () => ({
      'data-testid': 'dropzone-root',
      onClick: jest.fn(),
      onDrop: jest.fn(),
      onDragOver: jest.fn(),
      onDragLeave: jest.fn(),
    }),
    getInputProps: () => ({
      'data-testid': 'dropzone-input',
      type: 'file',
      multiple: true,
      accept,
      disabled,
    }),
    isDragActive: false,
    isDragAccept: false,
    isDragReject: false,
    acceptedFiles: [],
    rejectedFiles: [],
    open: jest.fn(),
  }),
}));

